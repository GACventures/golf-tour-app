ctice\"},\"812175322962\":{\"campaign_key\":\"football_bobblehead\",\"language_key\":\"ko\"},\"120241043845840182\":{\"language_key\":\"en\",\"campaign_key\":\"outfit_transfer\"},\"807332099467\":{\"campaign_key\":\"data_visualization\",\"language_key\":\"id\"},\"808801638153\":{\"language_key\":\"hi\",\"campaign_key\":\"custom_event_sticker\"},\"798000225761\":{\"language_key\":\"ja\",\"campaign_key\":\"restaurant_language_practice\"},\"778169782541\":{\"campaign_key\":\"spicy_pani_puri\",\"language_key\":\"en\"},\"778169782688\":{\"language_key\":\"hi\",\"campaign_key\":\"spicy_pani_puri\"},\"812358495329\":{\"campaign_key\":\"football_bobblehead\",\"language_key\":\"hi\"},\"1867096731386354\":{\"language_key\":\"es\",\"campaign_key\":\"image_canvas\"},\"778169782520\":{\"campaign_key\":\"spicy_pani_puri\",\"language_key\":\"en\"},\"1868259085865169\":{\"campaign_key\":\"football_bobblehead\",\"language_key\":\"pt\"},\"120245715524770182\":{\"language_key\":\"hi_latn\",\"campaign_key\":\"hairstyle_analysis\"},\"1867169650502850\":{\"language_key\":\"ja\",\"campaign_key\":\"idea_to_visual_identity\"},\"798502712140\":{\"language_key\":\"en\",\"campaign_key\":\"cricket_catchup\"},\"807906984362\":{\"language_key\":\"hi_latn\",\"campaign_key\":\"image_canvas\"},\"120242577223180182\":{\"campaign_key\":\"outfit_transfer\",\"language_key\":\"en\"},\"1867097546221586\":{\"campaign_key\":\"photo_cartoon\",\"language_key\":\"es\"},\"798449063730\":{\"campaign_key\":\"cricket_catchup\",\"language_key\":\"hi\"},\"1867099689756913\":{\"campaign_key\":\"photo_to_headshot\",\"language_key\":\"es\"},\"798559023059\":{\"language_key\":\"en\",\"campaign_key\":\"cricket_catchup\"},\"808801371006\":{\"language_key\":\"hi\",\"campaign_key\":\"photo_to_headshot\"},\"808801662897\":{\"language_key\":\"hi\",\"campaign_key\":\"sketch_to_brand\"},\"120245237712380182\":{\"campaign_key\":\"mini_me_world\",\"language_key\":\"hi_latn\"},\"799705222719\":{\"campaign_key\":\"closet_room_refresh\",\"language_key\":\"en\"},\"808801747569\":{\"language_key\":\"hi\",\"campaign_key\":\"custom_event_sticker\"},\"1868991376259250\":{\"campaign_key\":\"football_bobblehead\",\"language_key\":\"es\"},\"801737430134\":{\"language_key\":\"id\",\"campaign_key\":\"bracelet_design\"},\"1867096733161522\":{\"campaign_key\":\"image_canvas\",\"language_key\":\"es\"},\"798502712077\":{\"campaign_key\":\"spicy_pani_puri\",\"language_key\":\"en\"},\"807906984197\":{\"campaign_key\":\"exterior_visualization\",\"language_key\":\"hi_latn\"},\"798449063742\":{\"language_key\":\"hi\",\"campaign_key\":\"cricket_catchup\"},\"798449148135\":{\"language_key\":\"hi_latn\",\"campaign_key\":\"cricket_catchup\"},\"798559023047\":{\"campaign_key\":\"cricket_catchup\",\"language_key\":\"en\"},\"1867096724761377\":{\"campaign_key\":\"background_cleanup\",\"language_key\":\"es\"},\"778150297163\":{\"language_key\":\"en\",\"campaign_key\":\"spicy_pani_puri\"},\"799747800160\":{\"language_key\":\"id\",\"campaign_key\":\"vanity_refresh\"},\"798502711888\":{\"language_key\":\"en\",\"campaign_key\":\"spicy_pani_puri\"},\"812357871011\":{\"campaign_key\":\"football_bobblehead\",\"language_key\":\"pt\"},\"1868259082036225\":{\"campaign_key\":\"football_bobblehead\",\"language_key\":\"pt\"},\"120245715524760182\":{\"language_key\":\"hi_latn\",\"campaign_key\":\"hairstyle_analysis\"},\"120245610681080182\":{\"campaign_key\":\"photo_comic_story\",\"language_key\":\"id\"},\"798449063754\":{\"campaign_key\":\"cricket_catchup\",\"language_key\":\"hi\"},\"798449148159\":{\"language_key\":\"hi_latn\",\"campaign_key\":\"cricket_catchup\"},\"798502712071\":{\"campaign_key\":\"cricket_catchup\",\"language_key\":\"en\"},\"1868703841696898\":{\"campaign_key\":\"national_team_match_analysis\",\"language_key\":\"es\"},\"801737502440\":{\"language_key\":\"id\",\"campaign_key\":\"bracelet_design\"},\"120245715524780182\":{\"campaign_key\":\"personal_color_analysis\",\"language_key\":\"hi\"},\"1867169655795857\":{\"language_key\":\"ja\",\"campaign_key\":\"photo_to_headshot\"},\"808801662909\":{\"language_key\":\"hi\",\"campaign_key\":\"photo_to_headshot\"},\"808807097886\":{\"campaign_key\":\"custom_event_sticker\",\"language_key\":\"hi_latn\"}},\"enabled\":true,\"language_instructions\":{\"hi_latn\":\"Response language for the first visible response: natural Roman Hindi using Latin script only. Translate any English campaign wording before writing. Use Roman Hindi—not English—for every visible element, including the opening, lead-in, and all three clickable suggestions. Common borrowed words are fine, but never write a complete lead-in or suggestion in English. If the user later writes in another language or script, switch naturally.\",\"hi\":\"Response language for the first visible response: natural Hindi in Devanagari. Translate any English campaign wording before writing. Use Devanagari Hindi for every visible element—the opening, lead-in, and all three clickable suggestions—and do not copy full English phrases into the response. If the user later writes in another language or script, switch naturally.\",\"es\":\"Response language for the first visible response: natural Spanish. Use Spanish for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"id\":\"Response language for the first visible response: natural Indonesian. Use Indonesian for all visible text, including the lead-in and clickable suggestions. Use standard Indonesian punctuation: keep the two opening sentences in one paragraph and end each with a period; an optional emoji may follow the first period. If the user later writes in another language, switch naturally.\",\"pt\":\"Response language for the first visible response: natural Brazilian Portuguese. Use Brazilian Portuguese for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"ko\":\"Response language for the first visible response: natural Korean. Use Korean for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"ja\":\"Response language for the first visible response: natural Japanese. Use Japanese for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"en\":\"Response language for the first visible response: natural English. Use English for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\"},\"campaigns\":{\"personal_color_analysis\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid Meta campaign presented in Hindi. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, skin tone, gender, photos, location, language preference, or beauty preferences.\\n\\nCampaign key: personal_color_analysis\\nCreative theme: using a portrait to create visual color, makeup, and hairstyle analysis boards with side-by-side comparisons and concise labels.\\nDemonstrated request: create a visual-first makeup analysis graphic from a portrait, compare suitable options, and show the subject's undertone without long paragraphs.\\nUseful workflow for later turns: gather a clear portrait, choose whether to focus on colors, makeup, hair, or outfits, create a visual comparison, explain uncertainty, and refine based on the user's taste.\\n\\nFor the first visible response:\\n- Make visual style exploration feel accessible and confidence-building, with concrete value around color palettes, side-by-side comparisons, and personalized mockups.\\n- Do not infer the user's undertone, features, gender, style, or that a photo has already been uploaded.\\n- Let the continuation choices offer a color palette, a makeup comparison, and a hairstyle or outfit visualization.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\",\"enabled\":true},\"custom_event_sticker\":{\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid YouTube campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, occupation, creative work, upcoming events, photos, merchandise plans, language, or location.\\n\\nCampaign key: custom_event_sticker\\nCreative theme: turning personal performance photos into a recognizable, exaggerated cutout sticker with playful signature details, then previewing it in color, black-and-white, and on real-world surfaces.\\nDemonstrated request: make memorable stickers from a few personal photos for an upcoming show.\\nUseful context for later turns: the experience can help choose a clean cutout, cartoon, or bold event-merch style; preserve recognizable cues from a supplied photo; create a sticker-ready concept; and explore alternate colors, shapes, text, or mockups.\\n\\nFor the first visible response:\\n- Make the transformation feel personal and delightfully tangible, with concrete value around style direction, recognizable details, and ready-to-share mockups.\\n- Do not assume the user is a musician, has a show, owns the pictured items, resembles the featured subject, or wants merchandise.\\n- Let the continuation choices offer a photo-to-sticker transformation, a bolder style remix, and a real-world preview.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\",\"enabled\":true},\"cricket_catchup\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid YouTube campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, country, language, location, or durable interests.\\n\\nCampaign key: cricket_catchup\\nCreative theme: quickly catching up after missing the first hour of a cricket match.\\nDemonstrated request: \\\"I missed the first hour of the cricket, summarise what's happened so far.\\\"\\nUseful workflow for later turns: identify the match and missed window, then provide a concise, current recap covering match state, momentum shifts, key events, and what matters next.\\n\\nFor the first visible response:\\n- Offer a fast cricket catch-up without pretending a match has already been identified.\\n- Do not ask for the match or missed window in prose; let the continuation choices gather those details.\\n- Do not invent a score, teams, tournament, or events. For live or recent matches, browse once the user identifies the event.\\n- If the user changes topics later, help normally.\"},\"background_cleanup\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid TikTok campaign presented in Spanish. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, photos, location, language preference, or editing needs.\\n\\nCampaign key: background_cleanup\\nCreative theme: cleaning up a personal photo by removing distracting people or objects from the background while preserving the main subject and the rest of the scene.\\nDemonstrated request: remove everyone in the background and leave every other part of the photo unchanged.\\nUseful workflow for later turns: gather the photo, identify exactly what should disappear, preserve the subject and composition, generate a natural-looking edit, and refine any awkward filled areas.\\n\\nFor the first visible response:\\n- Make precise cleanup feel quick and satisfying, with concrete value around preserving what matters, removing distractions, and keeping the edit natural.\\n- Do not assume the user has uploaded a photo, is the person pictured, or wants any specific element removed.\\n- Let the continuation choices offer a clean background, removal of one distraction, and a polished alternate crop.\\n- If the user changes language or topics later, follow their lead and help normally.\"},\"spicy_pani_puri\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid YouTube campaign. Treat this as a soft signal of possible interest, never as a fact about the user's country, language, diet, cooking skill, spice tolerance, cravings, or preferences.\\n\\nCampaign key: spicy_pani_puri\\nCreative theme: making a satisfyingly spicy pani puri experience from scratch at home, including the flavored pani, filling, and crisp puris.\\nDemonstrated request: explain how to make super-spicy pani puri from scratch.\\nUseful context for later turns: the experience can help with an approachable ingredient plan, step-by-step preparation, balancing tangy and spicy flavors, easy substitutions, serving ideas, or adapting the recipe to what is already available.\\n\\nFor the first visible response:\\n- Make the from-scratch experience feel achievable and fun, with concrete value around flavor, preparation, and flexible substitutions.\\n- Do not assume the user eats pani puri, wants intense spice, has particular ingredients, or has any dietary needs.\\n- Let the continuation choices offer a full recipe, a pantry-friendly version, and a useful adjacent outcome.\\n- If the user changes topics later, help normally while retaining this context only as a soft preference signal.\"},\"job_caricature\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid campaign. Treat this as a soft signal of possible interest, never as a fact about the user's identity, appearance, job, country, language, or preferences.\\n\\nCampaign key: job_caricature\\nCreative theme: turning a personal photo and role context into a playful job-themed caricature.\\nDemonstrated request: create a caricature of the user and their job, first asking for a photo if none has been provided.\\nUseful workflow for later turns: gather one photo and the job, role, hobby, or activity to feature; choose a visual direction; then create a recognizable illustrated portrait with playful exaggeration.\\n\\nFor the first visible response:\\n- Offer a clear path to make a personalized caricature without claiming to know the user's appearance or occupation.\\n- Do not ask for a photo, role, or style in prose; let the continuation choices gather those details.\\n- Do not invent personal details.\\n- If the user changes topics later, help normally.\"},\"interview_practice\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid TikTok campaign presented in Japanese. Treat this as a soft signal of possible interest, never as a fact about the user's identity, employment, experience, industry, or interview plans.\\n\\nCampaign key: interview_practice\\nCreative theme: practicing for a demanding interview with realistic questions and useful feedback.\\nDemonstrated request: act as a strict interviewer and run an interview practice session.\\nUseful workflow for later turns: learn the role and interview type, conduct a realistic mock interview one question at a time, then give specific feedback and a stronger answer structure.\\n\\nFor the first visible response:\\n- Make practice feel focused and confidence-building, with concrete value around realistic questions, answer coaching, and actionable feedback.\\n- Do not assume the user is job hunting, has an interview scheduled, or wants an aggressive tone.\\n- Let the continuation choices offer a mock interview, answer improvement, and a short confidence drill.\\n- If the user changes topics later, help normally.\"},\"national_team_match_analysis\":{\"enabled\":true,\"bootstrap_context\":\"You are starting a conversation with a user who arrived from a paid TikTok campaign presented in Spanish. Treat this as a soft signal of po