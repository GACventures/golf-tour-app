                  </span><span class="ͼ13">&lt;Link</span><span>
                    </span><span class="ͼ12">className</span><span class="ͼv">=</span><span class="ͼz">"rounded-xl border px-4 py-2 text-sm font-medium hover:bg-gray-50"</span><span>
                    </span><span class="ͼ12">href</span><span class="ͼv">=</span><span>{</span><span class="ͼz">`/tours/</span><span>${</span><span class="ͼ11">t</span><span class="ͼv">.</span><span>id}</span><span class="ͼz">`</span><span>}
                  </span><span class="ͼ13">&gt;</span><span>
                    View
                  </span><span class="ͼ13">&lt;/Link&gt;</span><span>

                  </span><span class="ͼ13">&lt;Link</span><span>
                    </span><span class="ͼ12">className</span><span class="ͼv">=</span><span class="ͼz">"rounded-xl border px-4 py-2 text-sm font-medium hover:bg-gray-50"</span><span>
                    </span><span class="ͼ12">href</span><span class="ͼv">=</span><span>{</span><span class="ͼz">`/tours/</span><span>${</span><span class="ͼ11">t</span><span class="ͼv">.</span><span>id}</span><span class="ͼz">/leaderboard`</span><span>}
                  </span><span class="ͼ13">&gt;</span><span>
                    Leaderboard
                  </span><span class="ͼ13">&lt;/Link&gt;</span><span>

                  </span><span class="ͼ13">&lt;Link</span><span>
                    </span><span class="ͼ12">className</span><span class="ͼv">=</span><span class="ͼz">"rounded-xl bg-black px-4 py-2 text-sm font-medium text-white hover:bg-gray-800"</span><span>
                    </span><span class="ͼ12">href</span><span class="ͼv">=</span><span>{</span><span class="ͼz">`/tours/</span><span>${</span><span class="ͼ11">t</span><span class="ͼv">.</span><span>id}</span><span class="ͼz">`</span><span>}
                  </span><span class="ͼ13">&gt;</span><span>
