          </span><span class="ͼ13">&lt;div</span><span> </span><span class="ͼ12">className</span><span class="ͼv">=</span><span class="ͼz">"min-w-0"</span><span class="ͼ13">&gt;</span><span>
            </span><span class="ͼ13">&lt;div</span><span> </span><span class="ͼ12">className</span><span class="ͼv">=</span><span class="ͼz">"text-base font-semibold text-gray-900"</span><span class="ͼ13">&gt;</span><span>App User Guide</span><span class="ͼ13">&lt;/div&gt;</span><span>
