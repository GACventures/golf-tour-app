  </span><span class="ͼv">const</span><span> </span><span class="ͼ11">tourId</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼ11">String</span><span>(</span><span class="ͼ11">params</span><span>?.id </span><span class="ͼv">??</span><span> </span><span class="ͼz">""</span><span>)</span><span class="ͼv">.</span><span>trim();

  </span><span class="ͼv">if</span><span> (</span><span class="ͼv">!</span><span class="ͼ11">tourId</span><span> </span><span class="ͼv">||</span><span> </span><span class="ͼv">!</span><span class="ͼ11">isLikelyUuid</span><span>(</span><span class="ͼ11">tourId</span><span>)) {
