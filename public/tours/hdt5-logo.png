        </span><span class="ͼ13">&lt;section</span><span> </span><span class="ͼ12">className</span><span class="ͼv">=</span><span class="ͼz">"rounded-2xl border border-gray-200 bg-white shadow-sm p-4"</span><span class="ͼ13">&gt;</span><span>
          </span><span class="ͼ13">&lt;div</span><span> </span><span class="ͼ12">className</span><span class="ͼv">=</span><span class="ͼz">"text-sm text-gray-700 whitespace-pre-wrap leading-relaxed"</span><span class="ͼ13">&gt;</span><span>{</span><span class="ͼ11">guide</span><span>}</span><span class="ͼ13">&lt;/div&gt;</span><span>
