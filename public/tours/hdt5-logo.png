r(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div data-conversation-screenshot-content="" class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col agent-turn"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="assistant" data-message-id="4f5127d4-b587-4cb0-8d14-2bb8ad866083" dir="auto" data-message-model-slug="gpt-5-5" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden"><div class="markdown prose dark:prose-invert wrap-break-word w-full dark markdown-new-styling"><p data-start="0" data-end="37">That confirms the tour ID is correct.</p>
<p data-start="39" data-end="66">The correct mobile link is:</p>
<p data-start="68" data-end="155" class="" style=""><strong data-start="68" data-end="155"><a data-start="70" data-end="153" rel="noopener" target="_new" class="decorated-link" href="https://golf-tour-app-ivory.vercel.app/m/tours/3cdeb1ea-381e-41e0-8b91-aaadb5a4d0c3?utm_source=chatgpt.com">https://golf-tour-app-ivory.vercel.app/m/tours/3cdeb1ea-381e-41e0-8b91-aaadb5a4d0c3<span aria-hidden="true" class="ms-0.5 inline-block align-middle leading-none select-none"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" data-rtl-flip="" class="block h-[0.75em] w-[0.75em] stroke-current stroke-[0.75] select-none"><use href="/cdn/assets/sprites-core-fec7759e.svg#304883" fill="currentColor"></use></svg></span></a></strong></p>
<p data-start="157" data-end="206">So the problem is <strong data-start="175" data-end="182">not</strong> the URL or the tour ID.</p>
<h3 data-section-id="htmcgk" data-start="208" data-end="301">Since it works on your desktop but not on your phone, there are only a few likely causes.</h3>
<h4 data-start="303" data-end="354">1. The phone is trying to connect to localhost</h4>
<p data-start="355" data-end="499">If you've ever opened the app from your local development server (<code data-start="421" data-end="437">localhost:3000</code> or your PC's IP), the mobile app may have cached that origin.</p>
<p data-start="501" data-end="515">On your phone:</p>
<ul data-start="516" data-end="624">
<li data-section-id="1ss4gnu" data-start="516" data-end="553">
<p data-start="518" data-end="553">Close all browser tabs for the app.</p>
</li>
<li data-section-id="iib91r" data-start="554" data-end="585">
<p data-start="556" data-end="585">Open a brand new browser tab.</p>
</li>
<li data-section-id="p3fvss" data-start="586" data-end="624">
<p data-start="588" data-end="624">Manually paste the Vercel URL above.</p>
</li>
</ul>
<h4 data-start="626" data-end="683">2. A network request is failing after the page loads</h4>
<p data-start="684" data-end="856">The page itself may load, but one of the Supabase requests may be failing. The message "Cannot connect to the server" often comes from JavaScript rather than Vercel itself.</p>
<h4 data-start="858" data-end="893">3. An old deployment is cached</h4>
<p data-start="894" data-end="907">On the phone:</p>
<ul data-start="908" data-end="1014">
<li data-section-id="xgv25t" data-start="908" data-end="927">
<p data-start="910" data-end="927">Refresh the page.</p>
</li>
<li data-section-id="3hvt8y" data-start="928" data-end="970">
<p data-start="930" data-end="970">Or clear the browser cache for the site.</p>
</li>
<li data-section-id="bbx4lx" data-start="971" data-end="1014">
<p data-start="973" data-end="1014">Or try an Incognito/Private browsing tab.</p>
</li>
</ul>
<h3 data-section-id="7s766o" data-start="1016" data-end="1058">The quickest way to identify the cause</h3>
<p data-start="1060" data-end="1135">Could you tell me <strong data-start="1078" data-end="1095">exactly where</strong> you see "Cannot connect to the server"?</p>
<p data-start="1137" data-end="1149">For example:</p>
<ul data-start="1151" data-end="1426">
<li data-section-id="3a5o59" data-start="1151" data-end="1217">
<p data-start="1153" data-end="1217"><strong data-start="1153" data-end="1159">A.</strong> The browser itself displays "This site can't be reached."</p>
</li>
<li data-section-id="19t1vyg" data-start="1218" data-end="1308">
<p data-start="1220" data-end="1308"><strong data-start="1220" data-end="1226">B.</strong> The page opens, but your app shows a popup saying "Cannot connect to the server."</p>
</li>
<li data-section-id="yympl9" data-start="1309" data-end="1371">
<p data-start="1311" data-end="1371"><strong data-start="1311" data-end="1317">C.</strong> The page opens and is mostly blank with that message.</p>
</li>
<li data-section-id="1s2o28" data-start="1372" data-end="1426">
<p data-start="1374" data-end="1426"><strong data-start="1374" data-end="1380">D.</strong> Something else (a screenshot would be ideal).</p>
</li>
</ul>
<p data-start="1428" data-end="1447">One other question:</p>
<p data-start="1449" data-end="1544"><strong data-start="1449" data-end="1544">Does this happen only for the HDT5 tour, or does every mobile tour link fail on your phone?</strong></p>
<p data-start="1546" data-end="1600" data-is-last-node="" data-is-only-node="">That answer will narrow the problem down very quickly.</p></div></div></div></div><div class="z-0 flex min-h-[46px] justify-start"><div aria-label="Response actions" class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none touch:w-[calc(100%+--spacing(3.5))] -mt-1 w-[calc(100%+--spacing(2.5))] duration-[1.5s] focus-within:transition-none hover:transition-none touch:pointer-events-auto pointer-events-none [mask-image:linear-gradient(to_right,black_33%,transparent_66%)] [mask-size:300%_100%] [mask-position:100%_0%] motion-safe:transition-[mask-position] group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:[mask-position:0_0] group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:[mask-position:0_0] has-data-[state=open]:pointer-events-auto has-data-[state=open]:[mask-position:0_0]" role="group" tabindex="-1" style="mask-position: 0% 0%;"><button type="button" class="text-token-text-secondary hover:bg-token-surface-hover rounded-lg" aria-label="Copy response" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-fec7759e.svg#ce3544" fill="currentColor"></use></svg></span></button><button type="button" class="text-token-text-secondary hover:bg-token-surface-hover rounded-lg" aria-label="Good response" aria-pressed="false" data-testid="good-response-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-fec7759e.svg#51753c" fill="currentColor"></use></svg></span></button><button type="button" class="text-token-text-secondary ho